{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "EDAMAME workspace Renovate base config. Per-repo renovate.json files extend this via 'github>edamametechnologies/edamame_supply_chain:renovate-base.json'.",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Europe/Paris",
  "schedule": [
    "before 06:00 on monday"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "rangeStrategy": "pin",
  "rebaseWhen": "behind-base-branch",
  "labels": ["dependencies"],
  "minimumReleaseAge": "7 days",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 06:00 on monday"],
    "automerge": false
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "minimumReleaseAge": "0 days",
    "automerge": false
  },
  "packageRules": [
    {
      "description": "Never auto-merge anything. Every dep bump is operator-approved.",
      "matchManagers": ["cargo", "github-actions", "npm"],
      "automerge": false
    },
    {
      "description": "EDAMAME workspace crates: handled by commit_all.sh, NOT by Renovate. Disable so Renovate does not race the lockfile cascade.",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "edamame_core",
        "edamame_foundation",
        "edamame_helper",
        "edamame_posture",
        "edamame_cli",
        "edamame_backend",
        "flodbadd",
        "undeadlock",
        "threatmodels_rs",
        "extended-isolation-forest"
      ],
      "enabled": false
    },
    {
      "description": "Major Rust dep bumps: explicit review label, no auto-batch with patch bumps.",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["dep-major-review-required"],
      "groupName": null
    },
    {
      "description": "Minor + patch Rust dep bumps: group by week so the dependency dashboard stays readable.",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "rust-deps-weekly"
    },
    {
      "description": "GitHub Actions: pin to commit SHAs, not tags (defends against tag-rewrite supply-chain attacks).",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "GitHub Actions from edamametechnologies/* are first-party, no minimum-release-age delay.",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["edamametechnologies/**"],
      "minimumReleaseAge": "0 days"
    }
  ],
  "ignoreDeps": [],
  "osvVulnerabilityAlerts": true
}
